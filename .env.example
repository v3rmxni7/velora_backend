# Velora backend — environment variables (copy to .env; never commit .env)
# Phase 0: all service keys are optional so the app boots/typechecks without a live DB.

# Server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
CORS_ORIGIN=*

# Supabase (service-role key is BACKEND-ONLY — never expose to the frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# LLM providers (BYOK — added/used in Phase 1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY — reserved; the Google/Gemini provider is NOT yet wired (the LLM router fails over
# to deepseek/haiku). Setting it has no effect today.
GOOGLE_API_KEY=
# Cheap tier (Slice 3b) — DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Scraping (Firecrawl) — KB ingestion (Phase 1 Slice 1)
FIRECRAWL_API_KEY=

# Sending substrate (Smartlead) — Phase 2. Keys needed only for live send + webhooks.
# WEBHOOK_SECRET: a long random token YOU choose (Smartlead does not sign deliveries — no HMAC key
# exists in their product). Register the webhook URL WITH it: .../webhooks/smartlead?token=<value>
# (also accepted: payload-body secret_key, or a legacy HMAC header). See docs/RUNBOOK.md §7.3.
SMARTLEAD_API_KEY=
SMARTLEAD_API_URL=https://server.smartlead.ai/api/v1
SMARTLEAD_WEBHOOK_SECRET=

# Email verification (MillionVerifier) — Phase 2. Absent → verification skipped (sandbox).
MILLIONVERIFIER_API_KEY=

# Lead-data provider (lead-sourcing) — BYOK. LEAD_PROVIDER selects the find-leads source: 'seed'
# (default, zero-spend deterministic fixture) or 'apollo' (real, metered — needs APOLLO_API_KEY too;
# falls back to seed if the key is absent, so a forgotten key can never silently charge).
LEAD_PROVIDER=seed
APOLLO_API_KEY=
LEAD_SEARCH_COST=1
LEAD_DAILY_CAP_PER_ORG=25
LEAD_DAILY_CAP_GLOBAL=100

# DKIM selector (Slice 4.12) — absent → DKIM stays honestly 'unknown'; SPF + DMARC verify regardless.
DKIM_SELECTOR=

# Self-serve signup (Slice 4.13) — welcome credit grant on new-org provisioning (0 disables).
SIGNUP_GRANT_CREDITS=200

# Website-visitor de-anon resolver (Slice 4.6) — 🔌 EXTERNAL, not connected. Absent → resolver no-op.
WEBSITE_VISITOR_RESOLVER_API_KEY=

# CRM connect + sync (Slice 4.7) — 🔌 EXTERNAL, not configured. OAUTH_STATE_SECRET signs the OAuth CSRF state.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
OAUTH_STATE_SECRET=

# Send volume governor (Slice 2.9) — Velora-side daily send ceilings enforced at the send chokepoint.
DAILY_SEND_CAP_PER_ORG=50
DAILY_SEND_CAP_GLOBAL=200

# Anomaly circuit-breaker (Slice 3.5) — auto-pauses an org's autonomy on a bounce/complaint breach.
ANOMALY_BOUNCE_RATE=0.05
ANOMALY_MIN_SENDS=20
ANOMALY_MAX_COMPLAINTS=0
ANOMALY_WINDOW_HOURS=24
