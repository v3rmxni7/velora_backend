# Velora backend — environment variables (copy to .env; never commit .env)
# Phase 0: all service keys are optional so the app boots/typechecks without a live DB.

# Server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0
CORS_ORIGIN=*

# Supabase (service-role key is BACKEND-ONLY — never expose to the frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# LLM providers (BYOK — added/used in Phase 1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Scraping (Firecrawl) — KB ingestion (Phase 1 Slice 1)
FIRECRAWL_API_KEY=
